# ---------------------------------------------------------------------------
# Plantilla de variables de entorno para el proyecto Bocar.
#
# Uso:
#   1. Copia este archivo como `.env` en la raíz del proyecto (junto a manage.py).
#   2. Rellena los valores reales.
#   3. NO subas el archivo `.env` al repositorio (ya está en .gitignore).
# ---------------------------------------------------------------------------

# --- Notificaciones por correo ---------------------------------------------
# Activa/desactiva el envío de correos. Acepta: True / 1 / yes (default: False).
# Con el flag apagado no se encolan tareas (no requiere broker de Celery).
NOTIFICATIONS_ENABLED=False

# Backend de correo de Django.
# Desarrollo (default): consola — imprime los correos, no los envía.
# Producción: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Credenciales de la cuenta de correo (Microsoft 365 / Office 365).
BOCAR_EMAIL_USER=correo@dominio.com
BOCAR_EMAIL_PASSWORD=

# --- Celery ----------------------------------------------------------------
# URL del broker RabbitMQ.
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
