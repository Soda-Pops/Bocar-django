# ---------------------------------------------------------------------------
# Plantilla de variables de entorno para el proyecto Bocar.
#
# Uso:
#   1. Copia este archivo como `.env` en la raíz del proyecto (junto a manage.py).
#   2. Rellena los valores reales.
#   3. NO subas el archivo `.env` al repositorio (ya está en .gitignore).
# ---------------------------------------------------------------------------

# --- Django core -----------------------------------------------------------
# Genera uno con: python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'!@#$%^&*(-_=+)') for _ in range(60)))"
DJANGO_SECRET_KEY=replace-with-a-real-secret-key

# False en producción
DEBUG=True

# Coma-separado. Ej: midominio.com,www.midominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Notificaciones por correo ---------------------------------------------
# Activa/desactiva el envío de correos. Acepta: True / 1 / yes (default: False).
# Con el flag apagado no se encolan tareas (no requiere broker de Celery).
NOTIFICATIONS_ENABLED=False

# Backend de correo de Django.
# Desarrollo (default): consola — imprime los correos, no los envía.
# Producción: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Credenciales de la cuenta de correo (Microsoft 365 / Office 365).
BOCAR_EMAIL_USER=correo@dominio.com
BOCAR_EMAIL_PASSWORD=

# --- Celery ----------------------------------------------------------------
# URL del broker RabbitMQ.
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//

# --- Chatbot / LLM ---------------------------------------------------------
# Backend a usar: 'gemini' (default) o 'local' (Ollama en localhost).
LLM_BACKEND=gemini

# API Key de Google Gemini (requerida si LLM_BACKEND=gemini).
GEMINI_API_KEY=

# Modelo de Gemini a usar (default: gemini-2.0-flash).
GEMINI_MODEL=gemini-2.0-flash

# URL de Ollama si LLM_BACKEND=local (default: http://localhost:11434).
LOCAL_LLM_URL=http://localhost:11434

# Modelo de Ollama a usar si LLM_BACKEND=local (ej: llama3.2, mistral).
LOCAL_LLM_MODEL=llama3.2
